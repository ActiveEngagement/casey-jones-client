{
    "name": "actengage/casey-jones",
    "description": "The official package to communicate with Casey Jones.",
    "license": "MIT",
    "authors": [
        {
            "name": "Justin Kimbrell",
            "email": "jkimbrell@actengage.com"
        }
    ],
    "scripts": {
        "test": "pest",
        "types": "@php vendor/bin/testbench typescript:transform"
    },
    "require": {
        "php": "^8.3",
        "ext-redis": "*",
        "laravel/framework": "^13.0",
        "react/event-loop": "^1.5",
        "react/promise": "^3.2",
        "spatie/laravel-data": "^4.23",
        "actengage/laravel-message-gears": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "laravel/pint": "^1.8",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "mockery/mockery": "^1.6",
        "laravel/boost": "^2.0",
        "larastan/larastan": "^3.0",
        "rector/rector": "^2.0",
        "spatie/typescript-transformer": "^3.0",
        "spatie/laravel-typescript-transformer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Actengage\\CaseyJones\\": "src/",
            "Actengage\\CaseyJones\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4" : {
            "Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Actengage\\CaseyJones\\ServiceProvider"
            ],
            "aliases": {
                "Client": "Actengage\\CaseyJones\\Facades\\Client",
                "MessageGears": "Actengage\\CaseyJones\\Facades\\MessageGears"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
